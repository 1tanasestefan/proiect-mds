# ─────────────────────────────────────────────────────────────
# VibeTrips — Python AI Agent — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# ── Groq (AI inference — free tier available) ─────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Supabase ───────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
#
# SUPABASE_URL     : your project URL  (https://xxxx.supabase.co)
# SUPABASE_KEY     : service_role key  (starts with eyJhb... — NOT the anon/publishable key)
#                    Needed so the Python server can bypass RLS.
# SUPABASE_JWT_SECRET : JWT Secret string
#                    Supabase Dashboard → Settings → API → JWT Settings → "JWT Secret"
#                    It is a long random string, NOT the anon key and NOT the JWK kid.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhb...service_role_key_here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Server ────────────────────────────────────────────────────
PORT=8000
